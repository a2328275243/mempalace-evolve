{
  "version": 1,
  "policy": {
    "defaultMode": "all-configured",
    "autoEnableHighRisk": false,
    "secrets": "environment-only",
    "reviewRequiredForNewServers": true
  },
  "riskTags": [
    "browser",
    "desktop",
    "network-write",
    "filesystem-write",
    "credentialed"
  ],
  "servers": {
    "mempalace": {
      "description": "Local long-term memory MCP. Stop hooks may create candidates, but only reviewed candidates can be promoted.",
      "source": "local-bundled",
      "configPath": ".mcp.json#/mcpServers/mempalace",
      "command": "python",
      "args": [
        "-m",
        "mempalace_evolve.adapters.mcp_server"
      ],
      "risk": [
        "filesystem-write"
      ],
      "network": false,
      "readWrite": true,
      "defaultEnabled": true,
      "requires": [
        "DREAMSEED_MEMORY_DIR",
        "MEMPALACE_PATH"
      ],
      "outputLimitChars": 12000,
      "notes": "Memory writes must remain review-gated: memory_review.py apply -> reviewed/ -> memory_promote.py promote-reviewed."
    },
    "chrome-devtools": {
      "description": "Browser inspection MCP for local UI debugging and render validation.",
      "source": "npm:chrome-devtools-mcp",
      "configPath": ".mcp.json#/mcpServers/chrome-devtools",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "risk": [
        "browser",
        "network-write"
      ],
      "network": true,
      "readWrite": true,
      "defaultEnabled": true,
      "requires": [
        "Node.js",
        "Chrome"
      ],
      "secretSource": "none",
      "outputLimitChars": 12000,
      "notes": "Use for explicit browser/debug tasks; do not let it write credentials or browse private accounts without approval."
    },
    "github": {
      "description": "GitHub MCP server for repository, issue, pull request, and CI inspection.",
      "source": "local-bundled-github-mcp-server",
      "configPath": ".mcp.json#/mcpServers/github",
      "command": ".mcp-tools/github-mcp-server.exe",
      "args": [
        "stdio"
      ],
      "risk": [
        "network-write",
        "credentialed"
      ],
      "network": true,
      "readWrite": true,
      "defaultEnabled": true,
      "requires": [
        "GITHUB_PERSONAL_ACCESS_TOKEN"
      ],
      "secretSource": "environment-only",
      "outputLimitChars": 12000,
      "notes": "Token must come from the environment or private local config, never from publishable .mcp.json."
    },
    "desktop-commander": {
      "description": "Desktop command MCP for local filesystem and process assistance.",
      "source": "npm:@wonderwhy-er/desktop-commander",
      "configPath": ".mcp.json#/mcpServers/desktop-commander",
      "command": "npx",
      "args": [
        "-y",
        "@wonderwhy-er/desktop-commander@latest"
      ],
      "risk": [
        "desktop",
        "filesystem-write"
      ],
      "network": false,
      "readWrite": true,
      "defaultEnabled": true,
      "requires": [
        "Node.js"
      ],
      "secretSource": "none",
      "outputLimitChars": 12000,
      "notes": "High-risk desktop/filesystem operations must remain behind explicit approval."
    }
  },
  "candidates": {
    "browser-automation": {
      "source": "official-or-maintained-browser-mcp",
      "url": "https://modelcontextprotocol.io",
      "capability": "Browser inspection and interaction for local UI testing.",
      "type": "stdio",
      "command": "npx",
      "args": [
        "--yes",
        "@playwright/mcp"
      ],
      "risk": [
        "browser",
        "network-write"
      ],
      "network": true,
      "readWrite": true,
      "defaultState": "candidate",
      "secretSource": "none",
      "outputLimitChars": 12000,
      "dependencies": [
        "Node.js",
        "Playwright MCP"
      ],
      "adaptation": "Enable only for explicit browser testing tasks; keep disabled for normal coding.",
      "acceptance": [
        "dreamseed mcp test browser-automation",
        "dreamseed doctor mcp"
      ]
    },
    "desktop-control": {
      "source": "desktop-control-mcp-or-local-computer-use",
      "url": "https://modelcontextprotocol.io",
      "capability": "Desktop automation for approved local UI tasks.",
      "type": "stdio",
      "command": "desktop-mcp",
      "args": [],
      "risk": [
        "desktop",
        "filesystem-write"
      ],
      "network": false,
      "readWrite": true,
      "defaultState": "candidate",
      "secretSource": "none",
      "outputLimitChars": 12000,
      "dependencies": [
        "Local desktop MCP"
      ],
      "adaptation": "Keep candidate-only until a concrete desktop workflow requires it.",
      "acceptance": [
        "dreamseed mcp test desktop-control",
        "explicit user approval"
      ]
    },
    "github-tools": {
      "source": "github-mcp-or-gh-cli",
      "url": "https://github.com/modelcontextprotocol/servers",
      "capability": "Repository, issue, pull request, and CI triage.",
      "type": "stdio",
      "command": "github-mcp-server",
      "args": [],
      "risk": [
        "network-write",
        "credentialed"
      ],
      "network": true,
      "readWrite": true,
      "defaultState": "candidate",
      "secretSource": "environment-only",
      "outputLimitChars": 12000,
      "dependencies": [
        "GitHub token or authenticated gh"
      ],
      "adaptation": "Prefer read-only checks and gh CLI before enabling write-capable MCP.",
      "acceptance": [
        "dreamseed mcp test github-tools",
        "secret scan",
        "explicit user approval"
      ]
    }
  }
}
