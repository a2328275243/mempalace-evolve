{
  "mcpServers": {
    "mempalace": {
      "type": "stdio",
      "command": "python",
      "args": [
        "-m",
        "mempalace_evolve.adapters.mcp_server"
      ],
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "MEMPALACE_PATH": ".dreamseed-memory",
        "MEMPALACE_WING": "dreamseed"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@0.10.0"
      ]
    },
    "github": {
      "command": ".mcp-tools/github-mcp-server.exe",
      "args": [
        "stdio"
      ]
    },
    "desktop-commander": {
      "command": "npx",
      "args": [
        "-y",
        "@wonderwhy-er/desktop-commander@0.2.84"
      ]
    }
  }
}