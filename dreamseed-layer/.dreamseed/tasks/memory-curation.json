{
  "id": "memory-curation",
  "type": "memory-curation",
  "goal": "Curate memory candidates without polluting MemPalace.",
  "inputs": [
    "memory-candidates"
  ],
  "allowedTools": [
    "read",
    "shell"
  ],
  "forbiddenActions": [
    "direct MemPalace writes from hooks",
    "promote unreviewed candidates",
    "store secrets"
  ],
  "acceptance": [
    "dreamseed memory audit",
    "dreamseed memory reject-noisy",
    "dreamseed memory promote-reviewed --dry-run"
  ],
  "artifacts": [
    "memory-candidates/reviewed",
    "memory-candidates/rejected"
  ]
}
