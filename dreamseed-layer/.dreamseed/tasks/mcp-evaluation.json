{
  "id": "mcp-evaluation",
  "type": "mcp-evaluation",
  "goal": "Evaluate MCP servers before enabling them.",
  "inputs": [
    "config/mcp.registry.json",
    ".mcp.json"
  ],
  "allowedTools": [
    "read",
    "shell"
  ],
  "forbiddenActions": [
    "auto-enable high-risk MCP",
    "commit secrets"
  ],
  "acceptance": [
    "dreamseed mcp list",
    "dreamseed mcp candidates",
    "dreamseed doctor mcp"
  ],
  "artifacts": [
    "logs/evals/mcp"
  ]
}
