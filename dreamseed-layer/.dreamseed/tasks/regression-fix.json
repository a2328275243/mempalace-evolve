{
  "id": "regression-fix",
  "type": "regression-fix",
  "goal": "Fix regressions with reproduction and verification.",
  "inputs": [
    "failure output",
    "related files"
  ],
  "allowedTools": [
    "read",
    "shell",
    "edit after approval"
  ],
  "forbiddenActions": [
    "claim success without tests",
    "remove functionality to hide failures"
  ],
  "acceptance": [
    "focused reproduction passes",
    "dreamseed-smoke.ps1 passes when relevant"
  ],
  "artifacts": [
    "failure notes",
    "memory candidate if reusable"
  ]
}
