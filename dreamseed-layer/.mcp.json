{
  "mcpServers": {
    "mempalace": {
      "type": "stdio",
      "command": "python",
      "args": [
        "-m",
        "mempalace_evolve.adapters.mcp_server"
      ],
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "MEMPALACE_PATH": ".dreamseed-memory",
        "MEMPALACE_WING": "dreamseed"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "github": {
      "command": "D:/DreamSeed-Local-Agent/app/dreamseed-code-0.1.0/.mcp-tools/github-mcp-server.exe",
      "args": ["stdio"]
    },
    "desktop-commander": {
      "command": "npx",
      "args": ["-y", "@wonderwhy-er/desktop-commander@latest"]
    }
  }
}
